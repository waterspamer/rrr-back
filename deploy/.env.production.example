HOST=0.0.0.0
PORT=8083
NODE_ENV=production
LOG_LEVEL=INFO
CORS_ORIGIN=https://rrr-demo.tonforspeed.space
AUTO_START_COUNTDOWN_SEC=3
MATCH_TICK_RATE=20
MATCH_BROADCAST_RATE=20
MATCH_LOAD_TIMEOUT_SEC=10
DISCONNECT_TIMEOUT_SEC=10
ADMIN_TOKEN=
DIRECT_OBSERVER_URL=http://host.docker.internal:7777
DIRECT_OBSERVER_SECRET=
DIRECT_OBSERVER_REQUEST_TIMEOUT_SEC=3
